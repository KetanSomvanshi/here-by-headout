# HERE by Headout — environment. All optional locally; defaults run zero-config.
# Copy to .env and override only what you need. Hosting changes these, not code.

# SQLite file locally; on Fly use the volume path: sqlite:////data/here.db
DATABASE_URL=sqlite:///./here.db

# QR posters encode {APP_BASE_URL}/here/{token}. Set to the public URL when hosted
# (Cloudflare Tunnel or Fly), then regenerate posters so codes point at the live host.
APP_BASE_URL=http://localhost:8000

# Comma-separated allowed CORS origins. Match APP_BASE_URL.
CORS_ORIGINS=http://localhost:8000

# 1 loads Casa Aurelia Rome demo data on startup; tests force 0.
SEED_ON_STARTUP=1
